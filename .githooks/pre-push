#!/usr/bin/env bash
# Pre-push hook: run the same CI checks locally before pushing.
# Install: git config core.hooksPath .githooks

set -euo pipefail

# Skip checks for branch deletions (local_sha is all zeros)
has_non_delete=false
while read local_ref local_sha remote_ref remote_sha; do
    if [ "$local_sha" != "0000000000000000000000000000000000000000" ]; then
        has_non_delete=true
    fi
done
if [ "$has_non_delete" != "true" ]; then
    exit 0
fi

echo "==> Running pre-push checks..."

echo ""
echo "--- Lint (ruff) ---"
uv run ruff check

echo ""
echo "--- Tests (pytest) ---"
uv run pytest tests/ -q --tb=short

echo ""
echo "==> All checks passed. Pushing..."
